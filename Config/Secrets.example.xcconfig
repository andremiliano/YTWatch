// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and must never be committed.
//
// The YTM_API_KEY is the public YouTube Music web client key.
// Find it by opening music.youtube.com and inspecting any /youtubei/v1/ network request.

YTM_API_KEY = YOUR_YTM_API_KEY_HERE
